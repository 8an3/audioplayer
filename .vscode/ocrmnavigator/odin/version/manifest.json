 {
  "manifest_version": 3,
  "name": "Music Player",
  "version": "1.0",
  "permissions": ["storage","FileSystemHandle"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_icon": {
      "16": "icons/vulknut16.png",
      "32": "icons/vulknut32.png",
      "48": "icons/vulknut48.png",
      "128": "icons/vulknut128.png"
    }
  }
}